# ─── Backend API URL ──────────────────────────────────────────────────────────
# Only required in production when the frontend and backend are on different
# domains (e.g. frontend on Vercel, backend on Railway).
#
# Leave blank (or don't set) for local development — the Vite dev server
# already proxies /api → http://localhost:3000 automatically.
#
# Example (Railway):  VITE_API_URL=https://appointbot-be.up.railway.app
# Example (Render):   VITE_API_URL=https://appointbot-be.onrender.com
NODE_ENV=development
# In production set this to your Vercel frontend URL, e.g. https://appointbot.vercel.app
FRONTEND_URL=http://localhost:5173